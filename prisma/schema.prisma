generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTH & USERS
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  role          String    @default("coworker") // coworker | coworking_admin | super_admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Coworker profile
  coworkerProfile CoworkerProfile?

  // Coworking admin
  managedSpaces   CoworkingSpace[]

  // Marketplace
  listings        MarketplaceListing[]
  bookings        Booking[]
  eventRegistrations EventRegistration[]
}

// ==========================================
// COWORKER PROFILES
// ==========================================

model CoworkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  bio             String?
  profession      String?
  skills          String?  // comma-separated
  linkedinUrl     String?
  websiteUrl      String?
  avatarUrl       String?
  isPublic        Boolean  @default(true)
  services        String?  // what services they offer

  // Membership
  membershipTier  String?  // free | premium
  membershipStart DateTime?
  membershipEnd   DateTime?

  // Home coworking
  homeCoworkingId String?
  homeCoworking   CoworkingSpace? @relation("HomeCoworking", fields: [homeCoworkingId], references: [id])

  // Free monthly visit tracking
  freeVisits      FreeVisit[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FreeVisit {
  id              String   @id @default(cuid())
  profileId       String
  profile         CoworkerProfile @relation(fields: [profileId], references: [id])
  coworkingId     String
  coworking       CoworkingSpace @relation(fields: [coworkingId], references: [id])
  visitDate       DateTime
  month           Int
  year            Int
  createdAt       DateTime @default(now())
}

// ==========================================
// COWORKING SPACES
// ==========================================

model CoworkingSpace {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  shortDescription String?

  // Admin
  adminId         String?
  admin           User?    @relation(fields: [adminId], references: [id])

  // Location
  city            String
  region          String?  // Praha, Brno, Ostrava, etc.
  address         String?
  zipCode         String?
  latitude        Float?
  longitude       Float?

  // Details
  capacity        Int?     // number of seats
  areaM2          Int?     // area in m2
  phone           String?
  email           String?
  website         String?

  // Business hours (JSON string)
  openingHours    String?

  // Pricing
  priceDayPass    Float?
  priceMonthly    Float?
  priceHourly     Float?

  // Platform subscription
  platformTier    String?  // small | medium | large
  platformActive  Boolean  @default(false)

  // Status
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  isFeatured      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  amenities       CoworkingAmenity[]
  photos          CoworkingPhoto[]
  locations       CoworkingLocation[]
  events          Event[]
  bookings        Booking[]
  homeCoworkers   CoworkerProfile[] @relation("HomeCoworking")
  freeVisits      FreeVisit[]
}

model CoworkingAmenity {
  id            String   @id @default(cuid())
  coworkingId   String
  coworking     CoworkingSpace @relation(fields: [coworkingId], references: [id], onDelete: Cascade)
  amenity       String   // wifi | meeting_rooms | kitchen | parking | printer | phone_booth | shower | locker | reception | 24h_access | cafe | terrace | pet_friendly | childcare | workshop_tools
}

model CoworkingPhoto {
  id            String   @id @default(cuid())
  coworkingId   String
  coworking     CoworkingSpace @relation(fields: [coworkingId], references: [id], onDelete: Cascade)
  url           String
  caption       String?
  isPrimary     Boolean  @default(false)
  sortOrder     Int      @default(0)
}

model CoworkingLocation {
  id            String   @id @default(cuid())
  coworkingId   String
  coworking     CoworkingSpace @relation(fields: [coworkingId], references: [id], onDelete: Cascade)
  name          String?  // e.g. "Pobočka Vinohrady"
  address       String
  city          String
  zipCode       String?
  latitude      Float?
  longitude     Float?
  isPrimary     Boolean  @default(false)
}

// ==========================================
// EVENTS
// ==========================================

model Event {
  id              String   @id @default(cuid())
  coworkingId     String
  coworking       CoworkingSpace @relation(fields: [coworkingId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  eventType       String?  // workshop | networking | meetup | party | conference | other
  startDate       DateTime
  endDate         DateTime?
  isAllDay        Boolean  @default(false)
  maxAttendees    Int?
  price           Float?
  isFree          Boolean  @default(true)
  externalUrl     String?
  imageUrl        String?

  registrations   EventRegistration[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ==========================================
// BOOKINGS
// ==========================================

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  coworkingId   String
  coworking     CoworkingSpace @relation(fields: [coworkingId], references: [id])

  bookingType   String   // day_pass | hourly | monthly | meeting_room
  date          DateTime
  startTime     String?
  endTime       String?
  seats         Int      @default(1)
  totalPrice    Float?
  status        String   @default("pending") // pending | confirmed | cancelled
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// MARKETPLACE
// ==========================================

model MarketplaceListing {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  title         String
  description   String?
  category      String   // job_offer | job_seeking | service_offer | service_seeking | item_for_sale | item_wanted
  tags          String?  // comma-separated
  price         Float?
  priceType     String?  // fixed | hourly | negotiable | free
  location      String?
  isActive      Boolean  @default(true)
  contactEmail  String?
  contactPhone  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
