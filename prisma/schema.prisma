generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// NEXTAUTH - Required models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// USERS
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  role          String    @default("coworker") // coworker | coworking_admin | super_admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  coworkerProfile     CoworkerProfile?
  listings            MarketplaceListing[]
  events              Event[]
  bookings            Booking[]
  eventRegistrations  EventRegistration[]
  claims              CoworkingClaim[]
  ownedCoworkings     CoworkingEdit[]

  @@index([role])
  @@index([createdAt])
}

// ==========================================
// COWORKER PROFILES
// ==========================================

model CoworkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  bio             String?  @db.Text
  profession      String?
  skills          String?
  linkedinUrl     String?
  websiteUrl      String?
  avatarUrl       String?
  isPublic        Boolean  @default(true)
  services        String?  @db.Text

  membershipTier  String?
  membershipStart DateTime?
  membershipEnd   DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePlanInterval   String?

  homeCoworkingId   String?
  homeCoworkingSlug String?
  phone             String?
  company           String?
  isPhonePublic     Boolean  @default(false)
  isEmailPublic     Boolean  @default(false)
  isPhotoPublic     Boolean  @default(true)
  allowContact      Boolean  @default(false)
  freeVisits        FreeVisit[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublic])
  @@index([membershipTier])
  @@index([membershipEnd])
  @@index([stripeCustomerId])
  @@index([homeCoworkingSlug])
}

model FreeVisit {
  id              String   @id @default(cuid())
  profileId       String
  profile         CoworkerProfile @relation(fields: [profileId], references: [id])
  coworkingSlug   String
  visitDate       DateTime
  month           Int
  year            Int
  createdAt       DateTime @default(now())

  @@index([profileId])
  @@index([coworkingSlug])
}

// ==========================================
// COWORKING OWNERSHIP & EDITS
// ==========================================

model CoworkingClaim {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  coworkingSlug String
  coworkingName String
  status        String   @default("approved")
  businessEmail String?
  message       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, coworkingSlug])
  @@index([userId])
  @@index([status])
  @@index([coworkingSlug])
}

model CoworkingEdit {
  id            String   @id @default(cuid())
  coworkingSlug String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  data          Json
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ==========================================
// EVENTS
// ==========================================

model Event {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  coworkingSlug   String
  title           String
  description     String?  @db.Text
  eventType       String?
  startDate       DateTime
  endDate         DateTime?
  isAllDay        Boolean  @default(false)
  maxAttendees    Int?
  price           Float?
  isFree          Boolean  @default(true)
  location        String?
  externalUrl     String?
  imageUrl        String?
  registrations   EventRegistration[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([coworkingSlug])
  @@index([startDate])
  @@index([isFree])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

// ==========================================
// BOOKINGS
// ==========================================

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  coworkingSlug String
  bookingType   String
  date          DateTime
  startTime     String?
  endTime       String?
  seats         Int      @default(1)
  totalPrice    Float?
  status        String   @default("pending")
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([coworkingSlug])
  @@index([status])
  @@index([date])
}

// ==========================================
// MARKETPLACE
// ==========================================

model MarketplaceListing {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  title         String
  description   String?  @db.Text
  category      String
  tags          String?
  price         Float?
  priceType     String?
  location      String?
  isActive      Boolean  @default(true)
  contactEmail  String?
  contactPhone  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([isActive, createdAt])
  @@index([category])
}
