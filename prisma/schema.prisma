generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// NEXTAUTH - Required models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// USERS
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  role          String    @default("coworker") // coworker | coworking_admin | super_admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  coworkerProfile     CoworkerProfile?
  listings            MarketplaceListing[]
  events              Event[]
  bookings            Booking[]
  eventRegistrations  EventRegistration[]
  claims              CoworkingClaim[]
  ownedCoworkings     CoworkingEdit[]
  outgoingTransfers   CoworkingTransfer[]

  @@index([role])
  @@index([createdAt])
}

// ==========================================
// COWORKER PROFILES
// ==========================================

model CoworkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  bio             String?  @db.Text
  profession      String?
  skills          String?
  linkedinUrl     String?
  websiteUrl      String?
  avatarUrl       String?
  isPublic        Boolean  @default(true)
  services        String?  @db.Text

  membershipTier  String?
  membershipStart DateTime?
  membershipEnd   DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePlanInterval   String?

  homeCoworkingId   String?
  homeCoworkingSlug String?
  phone             String?
  company           String?
  isPhonePublic     Boolean  @default(false)
  isEmailPublic     Boolean  @default(false)
  isPhotoPublic     Boolean  @default(true)
  allowContact      Boolean  @default(false)
  freeVisits        FreeVisit[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublic])
  @@index([membershipTier])
  @@index([membershipEnd])
  @@index([stripeCustomerId])
  @@index([homeCoworkingSlug])
}

model FreeVisit {
  id              String   @id @default(cuid())
  profileId       String
  profile         CoworkerProfile @relation(fields: [profileId], references: [id])
  coworkingSlug   String
  visitDate       DateTime
  month           Int
  year            Int
  createdAt       DateTime @default(now())

  @@index([profileId])
  @@index([coworkingSlug])
}

// ==========================================
// COWORKING OWNERSHIP & EDITS
// ==========================================

model CoworkingClaim {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  coworkingSlug String
  coworkingName String
  status        String   @default("approved")
  businessEmail String?
  message       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, coworkingSlug])
  @@index([userId])
  @@index([status])
  @@index([coworkingSlug])
}

model CoworkingEdit {
  id            String   @id @default(cuid())
  coworkingSlug String   @unique  // internal original slug (immutable)
  customSlug    String?  @unique  // user-chosen URL slug (max 1× per 30 days)
  slugChangedAt DateTime?          // when customSlug was last changed
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  data          Json
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([customSlug])
}

/// Maps old custom slugs to new ones (for 301 redirects after slug change)
model SlugRedirect {
  id        String   @id @default(cuid())
  fromSlug  String   @unique
  toSlug    String
  createdAt DateTime @default(now())

  @@index([fromSlug])
}

model CoworkingTransfer {
  id            String   @id @default(cuid())
  coworkingSlug String
  fromUserId    String
  fromUser      User     @relation(fields: [fromUserId], references: [id])
  toEmail       String
  token         String   @unique
  status        String   @default("pending") // pending | accepted | cancelled
  message       String?  @db.Text
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([coworkingSlug])
  @@index([token])
  @@index([status])
}

// ==========================================
// EVENTS
// ==========================================

model Event {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  coworkingSlug   String
  title           String
  description     String?  @db.Text
  eventType       String?
  startDate       DateTime
  endDate         DateTime?
  isAllDay        Boolean  @default(false)
  maxAttendees    Int?
  price           Float?
  isFree          Boolean  @default(true)
  location        String?
  externalUrl     String?
  imageUrl        String?
  registrations   EventRegistration[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([coworkingSlug])
  @@index([startDate])
  @@index([isFree])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

// ==========================================
// BOOKINGS
// ==========================================

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  coworkingSlug String
  bookingType   String
  date          DateTime
  startTime     String?
  endTime       String?
  seats         Int      @default(1)
  totalPrice    Float?
  status        String   @default("pending")
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([coworkingSlug])
  @@index([status])
  @@index([date])
}

// ==========================================
// MARKETPLACE
// ==========================================

model MarketplaceListing {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  title         String
  description   String?  @db.Text
  category      String
  tags          String?
  price         Float?
  priceType     String?
  location      String?
  isActive      Boolean  @default(true)
  contactEmail  String?
  contactPhone  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([isActive, createdAt])
  @@index([category])
}

// ==========================================
// COW.OS — Coworking Operating System
// ==========================================

/// Coworking's subscription to the COW.OS module itself
model CowOsSubscription {
  id                   String   @id @default(cuid())
  coworkingSlug        String   @unique
  userId               String   // owner who activated
  tier                 String   @default("free") // free | standard | enterprise
  maxMembers           Int      @default(5)
  monthlyPrice         Int      @default(0)
  status               String   @default("active") // active | cancelled | past_due
  stripeSubscriptionId String?
  startDate            DateTime @default(now())
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([coworkingSlug])
  @@index([userId])
  @@index([status])
}

/// Billing identity of the coworking (supplier info on invoices)
model CowOsBillingProfile {
  id                String   @id @default(cuid())
  coworkingSlug     String   @unique
  companyName       String
  ico               String
  dic               String?  // VAT ID, null if not VAT payer
  address           String
  city              String
  zip               String
  bankAccount       String   // Czech format "číslo/kód"
  iban              String?  // For SPAYD QR
  isVatPayer        Boolean  @default(false)
  invoicePrefix     String   @default("COWOS")
  nextInvoiceNumber Int      @default(1)
  logoUrl           String?
  courtRegistration String?  // "Městský soud v Praze, oddíl C..."
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Membership plans offered by a coworking to its members
model CowOsMembershipPlan {
  id                 String   @id @default(cuid())
  coworkingSlug      String
  name               String   // "Hot Desk", "Fix Desk", "Private Office"
  description        String?  @db.Text
  basePrice          Float    // Monthly base price CZK
  billingInterval    String   @default("monthly") // monthly | yearly
  freeResourceHours  Int      @default(0) // Free meeting room hours/month
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members CowOsMember[]

  @@unique([coworkingSlug, name])
  @@index([coworkingSlug])
  @@index([coworkingSlug, isActive])
}

/// A member managed by a coworking
model CowOsMember {
  id              String   @id @default(cuid())
  coworkingSlug   String
  userId          String?  // linked User (nullable for external members)
  email           String
  name            String
  phone           String?
  company         String?
  ico             String?  // Member's IČO for B2B invoices
  planId          String
  plan            CowOsMembershipPlan @relation(fields: [planId], references: [id])
  status          String   @default("active") // active | trial | expired | cancelled
  startDate       DateTime @default(now())
  endDate         DateTime?
  nextRenewalDate DateTime?
  autoRenew       Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices CowOsInvoice[]

  @@unique([coworkingSlug, email])
  @@index([coworkingSlug])
  @@index([coworkingSlug, status])
  @@index([coworkingSlug, nextRenewalDate])
  @@index([userId])
  @@index([planId])
}

/// Invoices generated by the coworking for their members
model CowOsInvoice {
  id               String    @id @default(cuid())
  coworkingSlug    String
  memberId         String
  member           CowOsMember @relation(fields: [memberId], references: [id])
  invoiceNumber    String    // Sequential: "COWOS-001"
  issueDate        DateTime
  dueDate          DateTime
  paidDate         DateTime?
  status           String    @default("issued") // draft | issued | paid | overdue | cancelled
  subtotal         Float
  taxRate          Float     @default(0)
  taxAmount        Float     @default(0)
  total            Float
  currency         String    @default("CZK")
  items            Json      // [{description, quantity, unitPrice, total}]
  supplierName     String
  supplierIco      String
  supplierDic      String?
  supplierAddress  String
  recipientName    String
  recipientIco     String?
  recipientAddress String?
  bankAccount      String
  iban             String?
  variableSymbol   String
  qrPaymentCode    String?   @db.Text // SPAYD string
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())

  @@index([coworkingSlug])
  @@index([coworkingSlug, status])
  @@index([memberId])
  @@index([dueDate])
  @@index([invoiceNumber])
}

/// Bookable resources (meeting rooms, booths) — UI built later
model CowOsResource {
  id            String   @id @default(cuid())
  coworkingSlug String
  name          String
  type          String   // meeting_room | phone_booth | private_office | event_space
  capacity      Int?
  pricePerHour  Float    @default(0)
  description   String?  @db.Text
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([coworkingSlug])
  @@index([coworkingSlug, isActive])
}

/// Resource bookings with quota tracking — UI built later
model CowOsResourceBooking {
  id              String    @id @default(cuid())
  coworkingSlug   String
  resourceId      String
  memberId        String
  date            DateTime
  startTime       String
  endTime         String
  durationMinutes Int
  isFreeQuota     Boolean   @default(false)
  billableAmount  Float     @default(0)
  invoiceId       String?
  status          String    @default("confirmed") // confirmed | cancelled
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([coworkingSlug])
  @@index([resourceId, date])
  @@index([memberId, date])
  @@index([invoiceId])
}
